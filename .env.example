NODE_ENV=development

# ─── Required ────────────────────────────────────────────────────────
# Supabase: use cloud credentials OR local Supabase (npx supabase start).
# Local Supabase defaults:
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon key from supabase start output>

DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Site URL (used for SEO metadata, defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Optional: Email (Resend) ───────────────────────────────────────
# Leave empty to disable email sending. The /api/mail/send endpoint
# will return "Email service not configured" when these are not set.
RESEND_API_KEY=
RESEND_EMAIL_FROM=

# ─── Optional: Rate Limiting (Upstash Redis) ────────────────────────
# Leave empty to disable rate limiting. All API routes will work
# normally without it — requests just won't be rate-limited.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: Tavily API (Content Extraction) ────────────────────
# Leave empty to disable Tavily extraction. The previewScrape action
# will return an error when this is not set.
TAVILY_API_KEY=

# ─── Optional: AI API (AI Content Generation) ────────────────────
# Required for AI-powered content generation in workflows.
# Leave empty to disable AI generation - workflows will use mock data.
# Get your free API key from: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# ─── Optional: Workflow API Authentication ───────────────────────
# Leave empty to allow public access to workflow API endpoints.
# Set to a random string to require Bearer token authentication.
# Used to protect /api/workflows/* endpoints from unauthorized access.
WORKFLOW_SECRET=
